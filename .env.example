# Strava OAuth App — https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Supabase — https://supabase.com → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=

# Your app URL (Vercel deployment URL or localhost for dev)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Session encryption key — generate with: openssl rand -base64 32
SESSION_SECRET=

# Strava webhook verification token — any random string
STRAVA_WEBHOOK_VERIFY_TOKEN=
